# SvelteKit frontend
# Server-only Payload REST API base URL used by SvelteKit server code.
CMS_API_URL=https://cms.example.com

# Browser-safe public CMS origin for links/assets only. Do not put secrets here.
PUBLIC_CMS_URL=https://cms.example.com

# HTTP-only authentication cookie settings used by SvelteKit.
SESSION_COOKIE_NAME=parallel_market_session
SESSION_COOKIE_SECURE=true

# Frontend mock preview mode. Keep false in staging/production.
FRONTEND_MOCK_MODE=false

# Deployment platforms usually set NODE_ENV automatically.
NODE_ENV=production

# Payload CMS
# Public server URL for the Payload app itself. No path, only origin.
CMS_SERVER_URL=https://cms.example.com

# Private Neon/PostgreSQL connection string for Payload CMS.
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST/DATABASE_NAME?sslmode=require&channel_binding=require

# Private Payload signing secret. Use a long random value locally and in deployment.
PAYLOAD_SECRET=replace-with-a-long-random-secret

# CORS
# Comma-separated frontend/admin origins that are allowed to call the CMS. Do not use *.
CORS_ORIGINS=https://app.example.com,https://cms.example.com

# Optional protected cron secret for future maintenance jobs. Not used in Phase 6.
CRON_SECRET=

# Development seed administrator. Use private local values; never reuse production credentials.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=

# Future AI integration - not used for real simulation generation in Phase 6.
AI_PROVIDER_API_KEY=
AI_PROVIDER_MODEL=
