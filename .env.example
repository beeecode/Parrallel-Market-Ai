# SvelteKit frontend
# Browser-safe CMS base URL consumed by the future SvelteKit frontend.
PUBLIC_CMS_URL=http://localhost:3001

# Payload CMS
# Public server URL for the Payload app itself.
CMS_SERVER_URL=http://localhost:3001

# Private PostgreSQL connection string for Payload CMS.
DATABASE_URL=postgresql://username:password@localhost:5432/parallel_market_ai

# Private Payload signing secret. Use a long random value locally and in deployment.
PAYLOAD_SECRET=replace-with-a-long-random-secret

# CORS
# Comma-separated origins that will be allowed to call the CMS in later phases.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Development seed administrator. Use private local values; never reuse production credentials.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=

# Future AI integration - not used in Phase 3.
AI_PROVIDER_API_KEY=
AI_PROVIDER_MODEL=
