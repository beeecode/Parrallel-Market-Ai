# Payload CMS server URL used by Payload itself.
CMS_SERVER_URL=http://localhost:3001

# Private PostgreSQL connection string for the local Payload database.
# Replace USERNAME, PASSWORD, HOST, PORT, and DATABASE_NAME in your local .env file.
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME

# Private Payload signing secret. Use a long random value locally and in deployment.
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Comma-separated origins allowed to call the CMS.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Development seed administrator. Required only when running the seed command.
# Use private local values and never reuse production credentials.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
