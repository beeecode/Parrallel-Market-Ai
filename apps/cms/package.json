{
  "name": "@parallel-market-ai/cms",
  "version": "0.1.0",
  "description": "Payload CMS foundation for Parallel Market AI.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:status": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:status",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation payload run src/seed/seed.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3001",
    "test": "cross-env NODE_OPTIONS=--no-deprecation vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@faceless-ui/modal": "^3.0.0",
    "@faceless-ui/scroll-info": "^2.0.0",
    "@parallel-market-ai/shared-types": "workspace:*",
    "@parallel-market-ai/validation": "workspace:*",
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "16.2.6",
    "payload": "3.85.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "10.4.1",
    "globals": "17.6.0",
    "jsdom": "28.0.0",
    "prettier": "^3.4.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
