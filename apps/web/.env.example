# SvelteKit frontend
# Server-only Payload REST API base URL. Configure on Vercel as a private environment variable.
CMS_API_URL=https://cms.example.com

# Browser-safe public CMS origin for links/assets only. Do not put private values here.
PUBLIC_CMS_URL=https://cms.example.com

# Optional HTTP-only cookie name. Keep this value server-only.
SESSION_COOKIE_NAME=parallel_market_session

# Force secure cookies in production. Local HTTP development may set this to false.
SESSION_COOKIE_SECURE=true

# Optional frontend preview mode.
# Set to true only when you want to view the SvelteKit UI without Payload CMS or PostgreSQL.
FRONTEND_MOCK_MODE=false

# Deployment platforms usually set NODE_ENV automatically.
NODE_ENV=production
